{
  "productName": "Lesepult",
  "version": "0.3.0",
  "identifier": "de.s16e.lesepult",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "bundle": {
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "role": "Viewer",
        "description": "Markdown Document"
      }
    ],
    "icon": [
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon-256.png",
      "icons/icon-512.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Lesepult",
        "width": 800,
        "height": 1000,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
